# Rounds environment contract.
# Source-of-truth values live in Railway env (prod) or your local .env (dev).
# Mirrors the MIC audit §6 var contract, minus vestigial fields (Vault, VERTEX_AI_GEMINI_API_KEY).

# ── Required ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rounds:rounds_dev_pw@localhost:5432/rounds
REDIS_URL=redis://localhost:6379/0
GCP_PROJECT_ID=
GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-key.json
API_SECRET_KEY=
AUTH_USERS=johndean@vin.com:change_me

# ── Optional (have safe defaults) ─────────────────────────────────────
ENVIRONMENT=development
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

MAX_CONCURRENT_SESSIONS=3
MAX_QUEUE_LENGTH=10
MAX_UPLOAD_SIZE_MB=2048
MAX_VIDEO_DURATION_MINUTES=180

# Processing — LOCKED values from MIC audit §6. Do not tune.
FRAME_SAMPLE_FPS=2
VISUAL_CHANGE_THRESHOLD=8.0
ANCHOR_CROSS_VALIDATE_WINDOW=5.0
SOFT_WINDOW_EXPANSION=5.0
BOUNDARY_MERGE_WINDOW=3.0

FUSION_WEIGHT_VISUAL=0.5
FUSION_WEIGHT_ANCHOR=0.3
FUSION_WEIGHT_SEMANTIC=0.2
FUSION_BOUNDARY_THRESHOLD=0.35

ALIGN_WEIGHT_SEMANTIC=0.35
ALIGN_WEIGHT_COVERAGE=0.25
ALIGN_WEIGHT_TEMPORAL=0.25
ALIGN_WEIGHT_SEQUENTIAL=0.15
ALIGN_SEQUENTIAL_PENALTY=0.8

IIL_DRIFT_CONFIDENCE_PENALTY=0.3
IIL_DRIFT_REALIGN_WINDOW=20.0
IIL_TIER2_DEFAULT_THRESHOLD=0.7
IIL_TIER2_MODERATE_THRESHOLD=0.85

CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF_BASE=60
CELERY_RETRY_JITTER=true
IDEMPOTENCY_KEY_TTL_SECONDS=86400

# ── Transcription ─────────────────────────────────────────────────────
TRANSCRIPTION_BACKEND=google_stt_chunked
TRANSCRIPTION_CHUNK_MINUTES=5
WHISPER_MODEL_SIZE=base

# ── AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_CLASSIFY_MODEL=gemini-2.5-flash-lite
VERTEX_AI_CLASSIFY_ENABLED=false
VERTEX_AI_LOCATION=us-central1

# ── Railway production only ───────────────────────────────────────────
# GCP_KEY_B64=        # base64 of secrets/gcp-key.json; decoded by scripts/start.sh
# PORT=8000            # set by Railway
