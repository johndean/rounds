{
  "name": "rounds-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint src --ext .ts,.tsx,.vue",
    "typecheck": "vue-tsc --noEmit",
    "test:e2e": "playwright test --config=tests/playwright.config.ts",
    "test:visual": "playwright test --config=tests/visual/playwright.config.ts",
    "capture-baselines": "node ../scripts/capture-prototype-baselines.mjs"
  },
  "dependencies": {
    "vue": "^3.4.38",
    "vue-router": "^4.4.5",
    "pinia": "^2.2.4",
    "lucide-vue-next": "^0.460.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.9.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.15.0",
    "eslint-plugin-vue": "^9.31.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.10",
    "vue-tsc": "^2.1.10"
  }
}
